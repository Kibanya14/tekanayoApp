# ============================================================================
# 🚀 TEKANAYOAPP - FICHIER DE CONFIGURATION COMPLET (.env)
# ============================================================================
# ⚠️  À NE PAS COMMITTER SUR GITHUB!
# 👤 REMPLIR AVEC VOS PROPRES VALEURS
# ============================================================================

# ============================================================================
# 1️⃣  CONFIGURATION FLASK DE BASE
# ============================================================================

# Environnement d'exécution (development, production, staging, testing)
FLASK_ENV=development

# Clé secrète pour les sessions et CSRF (générer avec: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Mode debug (True en développement, False en production)
DEBUG=True

# Version de l'application
APP_VERSION=1.0.0

# ============================================================================
# 2️⃣  BASE DE DONNÉES
# ============================================================================

# Format: postgresql://user:password@host:port/database
# Ou SQLite: sqlite:///database.db
DATABASE_URL=sqlite:///database.db

# URL Supabase pour storage (optionnel)
SUPABASE_URL=

# Clé de service Supabase (Service Role Key - GARDEZ SECRET!)
SUPABASE_SERVICE_ROLE_KEY=

# Nom du bucket Supabase pour uploads
SUPABASE_BUCKET=uploads

# ============================================================================
# 3️⃣  CONFIGURATION EMAIL (SMTP)
# ============================================================================

# Serveur SMTP
MAIL_SERVER=smtp.gmail.com

# Port SMTP (587 pour TLS, 465 pour SSL)
MAIL_PORT=587

# Utiliser TLS (True/False)
MAIL_USE_TLS=True

# Utiliser SSL (True/False - généralement False si TLS=True)
MAIL_USE_SSL=False

# Email expéditeur
MAIL_USERNAME=

# Mot de passe email (App Password pour Gmail)
MAIL_PASSWORD=

# Email par défaut pour les envois
MAIL_DEFAULT_SENDER=

# Supprimer les envois d'email (utile en développement)
MAIL_SUPPRESS_SEND=False

# ============================================================================
# 4️⃣  CONFIGURATION ADMIN / SUPER ADMIN
# ============================================================================

# Prénom du super admin initial
SUPERADMIN_FIRST_NAME=

# Nom du super admin initial
SUPERADMIN_LAST_NAME=

# Email du super admin initial
SUPERADMIN_EMAIL=

# Mot de passe du super admin initial (sera changé à la première connexion)
SUPERADMIN_PASSWORD=

# ============================================================================
# 5️⃣  CONFIGURATION PAIEMENT - MOBILE MONEY (Afrique)
# ============================================================================

# === AIRTEL MONEY ===
AIRTEL_API_KEY=

AIRTEL_API_SECRET=

AIRTEL_MERCHANT_ID=

# === ORANGE MONEY ===
ORANGE_API_KEY=

ORANGE_API_SECRET=

ORANGE_MERCHANT_ID=

# === M-PESA ===
MPESA_API_KEY=

MPESA_API_SECRET=

MPESA_CONSUMER_KEY=

MPESA_CONSUMER_SECRET=

# === AFRIMONEY ===
AFRIMONEY_API_KEY=

AFRIMONEY_API_SECRET=

# === MTN MOMO (Mali, Sénégal, etc) ===
MTN_MOMO_API_KEY=

MTN_MOMO_API_SECRET=

MTN_MOMO_SUBSCRIPTION_KEY=

# ============================================================================
# 6️⃣  CONFIGURATION PAIEMENT - CARTES & INTERNATIONAL
# ============================================================================

# === PAYPAL ===
PAYPAL_CLIENT_ID=

PAYPAL_CLIENT_SECRET=

PAYPAL_MODE=sandbox

# === STRIPE ===
STRIPE_PUBLISHABLE_KEY=

STRIPE_SECRET_KEY=

STRIPE_WEBHOOK_SECRET=

# === FLUTTERWAVE (Agrégateur de paiements) ===
FLW_PUBLIC_KEY=

FLW_SECRET_KEY=

FLW_ENCRYPTION_KEY=

FLW_WEBHOOK_SECRET=

# ============================================================================
# 7️⃣  CONFIGURATION DEVISE & FINANCE
# ============================================================================

# Taux de change USD vers CDF (ex: 1 USD = 2800 CDF)
EXCHANGE_RATE_USD_CDF=2800

# Devise par défaut (USD, CDF, etc)
BASE_CURRENCY=CDF

# ============================================================================
# 8️⃣  CONFIGURATION DOMAINES PERSONNALISÉS
# ============================================================================

# Adresse IP du serveur Tekanayo
TEKANAYO_SERVER_IP=92.132.145.33

# Domaine principal de l'application
TEKANAYO_APP_HOST=tekanayo.com

# ============================================================================
# 9️⃣  CONFIGURATION ANTIVIRUS (ClamAV - Optionnel)
# ============================================================================

# Activer la vérification antivirus
ANTIVIRUS_ENABLED=False

# Adresse du serveur ClamAV
CLAMAV_HOST=localhost

# Port ClamAV
CLAMAV_PORT=3310

# Timeout de vérification (secondes)
ANTIVIRUS_TIMEOUT=30

# ============================================================================
# 🔟 CONFIGURATION MONITORING & LOGGING
# ============================================================================

# === SENTRY (Error Tracking) ===
SENTRY_DSN=

# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# === SENTRY ENVIRONMENT ===
SENTRY_ENVIRONMENT=development

# Percentage d'erreurs à tracer (0.0 à 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1

# === CLOUDINARY (Image Processing - Optionnel) ===
CLOUDINARY_CLOUD_NAME=

CLOUDINARY_API_KEY=

CLOUDINARY_API_SECRET=

# ============================================================================
# 1️⃣1️⃣ CONFIGURATION SÉCURITÉ
# ============================================================================

# Forcer HTTPS (True en production)
FORCE_HTTPS=False

# Domaines autorisés (CORS)
ALLOWED_HOSTS=localhost,127.0.0.1,tekanayo.com

# Salt pour le hash des mots de passe
PASSWORD_HASH_SALT=

# ============================================================================
# 1️⃣2️⃣ CONFIGURATION STOCKAGE FICHIERS
# ============================================================================

# Dossier root pour uploads locaux
UPLOAD_ROOT=uploads/

# Taille max upload (en MB)
MAX_UPLOAD_SIZE=50

# Extensions fichiers autorisées (séparées par virgule)
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,txt

# ============================================================================
# 1️⃣3️⃣ CONFIGURATION REDIS (Cache - Optionnel)
# ============================================================================

# URL de connexion Redis
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# 1️⃣4️⃣ CONFIGURATION TWILIO (SMS - Optionnel)
# ============================================================================

# Compte SID Twilio
TWILIO_ACCOUNT_SID=

# Token Auth Twilio
TWILIO_AUTH_TOKEN=

# Numéro téléphone Twilio
TWILIO_PHONE_NUMBER=

# ============================================================================
# 1️⃣5️⃣ CONFIGURATION AWS S3 (Stockage cloud - Optionnel)
# ============================================================================

# Région AWS
AWS_REGION=

# Access Key ID
AWS_ACCESS_KEY_ID=

# Secret Access Key
AWS_SECRET_ACCESS_KEY=

# Nom du bucket S3
AWS_S3_BUCKET=

# ============================================================================
# 1️⃣6️⃣ CONFIGURATION GOOGLE MAPS (Géolocalisation)
# ============================================================================

# Clé API Google Maps
GOOGLE_MAPS_API_KEY=

# ============================================================================
# 1️⃣7️⃣ CONFIGURATION GOOGLE ANALYTICS
# ============================================================================

# ID de suivi Google Analytics
GOOGLE_ANALYTICS_ID=

# ============================================================================
# 1️⃣8️⃣ CONFIGURATION RECAPTCHA (Protection bot)
# ============================================================================

# Clé publique reCAPTCHA v3
RECAPTCHA_SITE_KEY=

# Clé secrète reCAPTCHA v3
RECAPTCHA_SECRET_KEY=

# ============================================================================
# 1️⃣9️⃣ CONFIGURATION JWT (Token d'authentification - API)
# ============================================================================

# Clé secrète JWT
JWT_SECRET_KEY=

# Durée de vie token (secondes)
JWT_EXPIRATION_TIME=3600

# ============================================================================
# 2️⃣0️⃣ CONFIGURATION SLACK (Notifications - Optionnel)
# ============================================================================

# Webhook URL Slack
SLACK_WEBHOOK_URL=

# ============================================================================
# 2️⃣1️⃣ CONFIGURATION GITHUB (Déploiement - Optionnel)
# ============================================================================

# Token GitHub pour déploiement automatique
GITHUB_TOKEN=

# ============================================================================
# 2️⃣2️⃣ CONFIGURATION DOCKER (Si utilisation Docker)
# ============================================================================

# Port d'exposition du conteneur
CONTAINER_PORT=5000

# ============================================================================
# 2️⃣3️⃣ CONFIGURATION RENDER / HEROKU
# ============================================================================

# URL de la base de données PostgreSQL (Render/Heroku)
DATABASE_URL=

# ============================================================================
# 2️⃣4️⃣ CONFIGURATION TESTS
# ============================================================================

# Database pour tests (généralement SQLite en mémoire)
TEST_DATABASE_URL=sqlite:///:memory:

# Activer les tests
TESTING=False

# ============================================================================
# 2️⃣5️⃣ CONFIGURATION TÂCHES PROGRAMMÉES (Celery - Optionnel)
# ============================================================================

# Broker Redis pour Celery
CELERY_BROKER_URL=redis://localhost:6379/1

# Backend Redis pour résultats
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================================
# 2️⃣6️⃣ CONFIGURATION NOTIFICATIONS PUSH (Optionnel)
# ============================================================================

# Clé Firebase Cloud Messaging
FCM_API_KEY=

# ============================================================================
# 2️⃣7️⃣ CONFIGURATION PARTENAIRES & INTÉGRATIONS
# ============================================================================

# === SUIVI COLIS (EasyPost / Shippo) ===
EASYPOST_API_KEY=

SHIPPO_API_KEY=

# === WEATHER API (Prévisions) ===
WEATHERAPI_KEY=

# === EXCHANGE RATE API (Taux de change) ===
EXCHANGERATE_API_KEY=

# ============================================================================
# 2️⃣8️⃣ CONFIGURATION DÉVELOPPEMENT LOCAL
# ============================================================================

# Hot reload (rechargement auto fichiers)
FLASK_DEBUG=True

# Logs détaillés
VERBOSE_LOGGING=True

# Désactiver cache en développement
DISABLE_CACHE=False

# ============================================================================
# 2️⃣9️⃣ CONFIGURATION RATE LIMITING
# ============================================================================

# Activer rate limiting
RATE_LIMIT_ENABLED=True

# Requêtes par minute par IP
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ============================================================================
# 3️⃣0️⃣ CONFIGURATION BACKUP (Optionnel)
# ============================================================================

# Activer les backups automatiques
BACKUP_ENABLED=False

# Fréquence des backups (daily, weekly)
BACKUP_FREQUENCY=weekly

# Destination des backups
BACKUP_DESTINATION=

# ============================================================================
# NOTES IMPORTANTES
# ============================================================================
#
# 1️⃣  SÉCURITÉ:
#    - Ne JAMAIS committer ce fichier sur GitHub!
#    - Utiliser .gitignore: .env
#    - Générer SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
